# Copy this file to .env and edit values for your machine.

# Any exact name shown by: ollama list
# Local and cloud models both work as long as Ollama lists them.
VIDEO_AI_MODEL=gemma4:e4b

# Optional. Needed only for WEB_GIF timeline entries.
GIPHY_API_KEY=

# Optional. Set this if ComfyUI is installed outside this project folder.
COMFYUI_DIR=D:\Software\ComfyUI
